# =============================================================================
# Required Environment Variables — app will fail to start if any are missing
# =============================================================================

# Core
DATABASE_URL=
ADMIN_SECRET=

# Solana
SOLANA_MINT_AUTHORITY_SECRET_KEY=
USDC_MINT_ADDRESS=
USDC_TREASURY_SECRET_KEY=

# Auth (Privy)
PRIVY_APP_SECRET=
GUEST_TOKEN_SECRET=
LOCAL_UPLOAD_SIGNING_SECRET=

# Storage (S3 / Cloudflare R2)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_URL=
S3_REGION=
STORAGE_MODE=local

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Campaign
GOLD_REWARD_USDC=

# Integrations
DRIP_API_KEY=
DRIP_API_URL=
TORQUE_API_KEY=

# Client-side (NEXT_PUBLIC_*)
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_ROUNDS_PER_SESSION=5
NEXT_PUBLIC_VOTING_ROUND_DURATION_IN_SECONDS=30
NEXT_PUBLIC_ENTRY_FEE_USDC=1.00
NEXT_PUBLIC_BASE_REWARD_USDC=1.75
NEXT_PUBLIC_TRIBE_TASTE_SCORE=70
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# =============================================================================
# Optional — defaults to false/undefined if not set
# =============================================================================
# SAMPLE_SESSION_ENABLED=true
# VRF_TESTING_MODE=true
