generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  player
  admin
}

enum SessionStatus {
  scheduled
  live
  ended
}

enum VoteDecision {
  video_a
  video_b
}

enum RewardTier {
  participation
  base
  gold
}

enum CampaignStatus {
  upcoming
  active
  completed
}

model User {
  id               String   @id @default(cuid())
  email            String?  @unique
  phone            String?
  displayName      String?
  profilePhoto     String?
  role             UserRole @default(player)
  consentAccepted  Boolean  @default(false)
  privyId          String   @unique
  walletAddress    String?
  referralCode     String   @unique
  referredBy       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  categories       Json?

  uploadedVideos   Video[]
  votes            Vote[]
  gameResults      GameResult[]
  referralsMade    Referral[] @relation("Referrer")
  referralReceived Referral?  @relation("Referred")
  enrollments      CampaignEnrollment[]
}

model Video {
  id             String   @id @default(cuid())
  title          String?
  url            String
  thumbnailUrl   String?
  duration       Int?
  uploadedById   String
  uploadedBy     User     @relation(fields: [uploadedById], references: [id])
  createdAt      DateTime @default(now())

  matchupsAsA    Matchup[] @relation("VideoA")
  matchupsAsB    Matchup[] @relation("VideoB")
  wonMatchups    Matchup[] @relation("WinningVideo")
}

model WeeklySession {
  id                String        @id @default(cuid())
  weekNumber        Int           @unique
  title             String
  scheduledAt       DateTime
  status            SessionStatus @default(scheduled)
  lateJoinCutoff    DateTime?
  collectionAddress String?
  vaultAddress      String?
  campaignId        String?
  campaign          Campaign?     @relation(fields: [campaignId], references: [id])

  matchups       Matchup[]
  gameResults    GameResult[]
}

model Matchup {
  id              String        @id @default(cuid())
  sessionId       String
  session         WeeklySession @relation(fields: [sessionId], references: [id])
  matchupNumber   Int
  videoAId        String
  videoA          Video         @relation("VideoA", fields: [videoAId], references: [id])
  videoBId        String
  videoB          Video         @relation("VideoB", fields: [videoBId], references: [id])
  duration        Int           @default(30)
  winningVideoId  String?
  winningVideo    Video?        @relation("WinningVideo", fields: [winningVideoId], references: [id])

  votes           Vote[]

  @@unique([sessionId, matchupNumber])
}

model Vote {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  matchupId   String
  matchup     Matchup      @relation(fields: [matchupId], references: [id])
  decision    VoteDecision
  submittedAt DateTime     @default(now())

  @@unique([userId, matchupId])
}

model GameResult {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  sessionId     String
  session       WeeklySession @relation(fields: [sessionId], references: [id])
  totalVotes    Int           @default(0)
  correctVotes  Int           @default(0)
  tier          RewardTier?
  rewardAmount  Float         @default(0)
  nftMinted     Boolean       @default(false)
  nftTokenId    String?
  nftRevealed   Boolean       @default(false)
  walletAddress String?
  joinedAt      DateTime      @default(now())
  lateJoin      Boolean       @default(false)
  usdcClaimed   Boolean       @default(false)
  claimTxHash   String?
  claimedAt     DateTime?

  @@unique([userId, sessionId])
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referrer       User     @relation("Referrer", fields: [referrerId], references: [id])
  referredUserId String   @unique
  referredUser   User     @relation("Referred", fields: [referredUserId], references: [id])
  code           String
  createdAt      DateTime @default(now())
}

model Campaign {
  id                      String          @id @default(cuid())
  cycleNumber             Int             @unique
  title                   String
  startDate               DateTime
  endDate                 DateTime
  status                  CampaignStatus  @default(upcoming)
  durationWeeks           Int
  sessionsPerCycle        Int
  videosPerSession        Int
  votingRoundDurationSecs Int             @default(30)
  matchupsPerSession      Int             @default(28)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  sessions    WeeklySession[]
  enrollments CampaignEnrollment[]
}

model CampaignEnrollment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  role       UserRole
  enrolledAt DateTime @default(now())

  @@unique([userId, campaignId])
}
